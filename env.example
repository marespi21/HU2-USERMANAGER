# Copia este archivo como .env.local y completa los valores.

# MongoDB Atlas (Módulo 3)
# IMPORTANTE: la contraseña va SIN los símbolos < y > (esos son solo un ejemplo de Atlas)
MONGODB_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster0.xxxxx.mongodb.net/user-manager?retryWrites=true&w=majority

# Gmail + Nodemailer (Módulo 11) — App Password, no tu contraseña normal
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
